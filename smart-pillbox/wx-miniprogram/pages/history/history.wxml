<!--pages/history/history.wxml-->
<view class="container">
  <view class="header">
    <text class="title">📊 历史数据</text>
  </view>

  <view class="time-tabs">
    <view wx:for="{{timeOptions}}" wx:key="value" class="time-tab {{selectedHours === item.value ? 'active' : ''}}" data-hours="{{item.value}}" bindtap="switchTime">{{item.label}}</view>
  </view>

  <view class="card">
    <text class="chart-title">🌡️ 温度变化 (℃)</text>
    <view class="bar-chart">
      <block wx:for="{{chartData}}" wx:key="timestamp">
        <view class="bar-wrapper">
          <view class="bar bar-temp" style="height: {{(item.temperature - minTemp) / (maxTemp - minTemp || 1) * 160}}rpx"></view>
          <text class="bar-label">{{item.time_label}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <text class="chart-title">💧 湿度变化 (%RH)</text>
    <view class="bar-chart">
      <block wx:for="{{chartData}}" wx:key="timestamp">
        <view class="bar-wrapper">
          <view class="bar bar-humi" style="height: {{(item.humidity - minHumi) / (maxHumi - minHumi || 1) * 160}}rpx"></view>
          <text class="bar-label">{{item.time_label}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <text class="chart-title">⚖️ 重量变化 (g)</text>
    <view class="bar-chart">
      <block wx:for="{{chartData}}" wx:key="timestamp">
        <view class="bar-wrapper">
          <view class="bar bar-weight" style="height: {{(item.weight - minWeight) / (maxWeight - minWeight || 1) * 160}}rpx"></view>
          <text class="bar-label">{{item.time_label}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <text class="chart-title">📋 近期吃药记录</text>
    <block wx:if="{{medRecords.length > 0}}">
      <view wx:for="{{medRecords}}" wx:key="time" class="med-item">
        <text class="med-time">{{item.time}}</text>
        <text class="med-change">{{item.weight_before}}g → {{item.weight_after}}g ↓</text>
        <text class="{{item.taken ? 'tag-ok' : 'tag-no'}}">{{item.taken ? '已服药' : '未服药'}}</text>
      </view>
    </block>
    <view wx:else class="empty-tip">暂无吃药记录</view>
  </view>
</view>