<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">💊 智能药盒</text>
    <text class="subtitle">设备: pillbox_001</text>
  </view>

  <view class="card-row">
    <view class="card card-temp">
      <view class="card-icon">🌡️</view>
      <text class="card-value">{{temperature}}°</text>
      <text class="card-label">温度 (℃)</text>
    </view>
    <view class="card card-humi">
      <view class="card-icon">💧</view>
      <text class="card-value">{{humidity}}%</text>
      <text class="card-label">湿度 (%RH)</text>
    </view>
  </view>

  <view class="card card-weight">
    <view class="card-icon">⚖️</view>
    <view class="weight-row">
      <text class="card-value big">{{weight}}</text>
      <text class="card-unit">克</text>
    </view>
    <text class="card-label">当前重量</text>
  </view>

  <view class="card card-med">
    <text class="section-title">📋 今日吃药记录</text>
    <block wx:if="{{medication.length > 0}}">
      <view wx:for="{{medication}}" wx:key="time_label" class="med-item {{item.taken ? 'taken' : 'missed'}}">
        <text class="med-time">{{item.time_label}}</text>
        <text class="med-status">{{item.taken ? '✅ 已服药' : '❌ 未服药'}}</text>
      </view>
    </block>
    <view wx:else class="empty-tip">暂无记录，等待数据...</view>
  </view>

  <view class="update-time">
    <text>更新于 {{timestamp || '--'}}</text>
    <text class="refresh-btn" bindtap="fetchAll">🔄 刷新</text>
  </view>
</view>